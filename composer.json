{
    "name": "builtbyotte/pterodactyl-sso",
    "description": "Allows clients from various applications login to their Pterodactyl account with a single redirect",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BuiltByOtte.com",
            "email": "contact@builtbyotte.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.0|^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "BuiltByOtte\\Sso\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BuiltByOtte\\Sso\\SsoServiceProvider"
            ]
        }
    }
